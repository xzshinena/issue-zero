# ---------------------------------------------------------------------------
# Issue Zero — environment variables
# Copy to .env and fill in values.
# ---------------------------------------------------------------------------

# ── Database ────────────────────────────────────────────────────────────────
# Option A: full connection string
DATABASE_URL=postgresql://user:password@localhost:5432/issue_zero

# Option B: individual parts (preferred — avoids URL-encoding issues with
# special characters in passwords). When DB_HOST is set, it takes priority.
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=tsdb
DB_SSLMODE=require

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal access token with `repo` scope (classic) or `issues:read` (fine-grained)
GITHUB_TOKEN=ghp_...

# Comma-separated list of repos to sync on startup / via scripts/sync_repos.py
REPOS_TO_SYNC=owner/repo,other-org/other-repo

# ── Embeddings ───────────────────────────────────────────────────────────────
# "sentence-transformers" uses a local model (no API key needed).
# "openai" calls the OpenAI Embeddings API (requires OPENAI_API_KEY).
EMBEDDING_PROVIDER=sentence-transformers

# Model name passed to the chosen provider.
# sentence-transformers default: all-MiniLM-L6-v2  (384-dim, fast, good quality)
# openai default:                text-embedding-3-small  (1536-dim)
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Dimension of the embedding vectors — must match the model and pgvector index.
EMBEDDING_DIM=384

# Required when EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=

# ── Optional: Celery (async job queue) ───────────────────────────────────────
# Only needed if you replace FastAPI BackgroundTasks with Celery workers.
# CELERY_BROKER_URL=redis://localhost:6379/0
