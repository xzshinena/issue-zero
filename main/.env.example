# Database (TimescaleDB / PostgreSQL with pgvector)
DB_HOST=localhost
DB_PORT=5432
DB_USER=tsdbadmin
DB_PASSWORD=your_password_here
DB_NAME=tsdb
DB_SSLMODE=require

# Alternative: single connection string (used if DB_HOST/USER/PASSWORD not set)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# GitHub personal access token
GITHUB_TOKEN=github_pat_XXXX
REPOS_TO_SYNC=owner/repo1,owner/repo2

# Embeddings: "sentence-transformers" (local, free) or "openai" (API, paid)
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# If using OpenAI embeddings
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL_NAME=text-embedding-3-small
# EMBEDDING_DIM=1536

# Celery (optional, for async ingestion)
# CELERY_BROKER_URL=redis://localhost:6379/0
